# This project uses DOPPLER to manage environment variables — there is no
# committed .env file. Secrets live in this project's Doppler project.
#
# Local setup (one time):
#   doppler login          # authenticate the CLI
#   doppler setup          # auto-scopes to the dev config via doppler.yaml
# Then `npm run dev`, `npm run db:migrate`, etc. inject env automatically.
#
# This file documents which variables the app expects. To inspect/edit them:
#   doppler secrets                       # list (dev config)
#   doppler secrets set KEY=value         # set one
#
# ---- Variables -------------------------------------------------------------

# Postgres connection string.
#  - Local dev:  postgresql://USER@localhost:5432/bolao
#  - Production: the POOLED Neon connection string (the one containing "-pooler").
DATABASE_URL=

# Secret used to sign the 30-day session cookie. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Resend API key for sending login codes (https://resend.com).
RESEND_API_KEY=
# Sender address. onboarding@resend.dev only delivers to your own Resend account
# email — verify a domain in Resend to email everyone.
EMAIL_FROM=Bolao da Copa <onboarding@resend.dev>

# Comma-separated emails that get admin powers (manage fixtures + results).
ADMIN_EMAILS=admin@example.com

# Comma-separated email domains allowed to log in.
ALLOWED_DOMAINS=example.com

# Football-data.org token for the live-results sync.
FOOTBALL_DATA_TOKEN=
# Shared secret protecting the /api/sync cron route.
CRON_SECRET=

# ---- PIX buy-ins via Asaas -------------------------------------------------
# Asaas API key (production keys start with $aact_prod_).
API_KEY_ASAAS=
# Asaas wallet id (account identifier).
WALLET_ASAAS=
ASAAS_BASE_URL=https://api.asaas.com/v3
# Secret configured on the Asaas webhook; sent back in the asaas-access-token header.
ASAAS_WEBHOOK_TOKEN=
# Pix address key (chave) the static QR codes are generated against.
ASAAS_PIX_ADDRESS_KEY=
# Public base URL (used for webhook reachability / links).
APP_URL=https://your-app.example.com
# CPF/CNPJ for the single internal "pool" customer Asaas bills under (the
# organizer's CPF). Required to create charges; payers never need to give theirs.
POOL_CPF=
