# This project uses DOPPLER to manage environment variables — there is no
# committed .env file. Secrets live in the `lcm-bolao` Doppler project.
#
# Local setup (one time):
#   doppler login          # authenticate the CLI
#   doppler setup          # auto-scopes to lcm-bolao/dev via doppler.yaml
# Then `npm run dev`, `npm run db:migrate`, etc. inject env automatically.
#
# This file documents which variables the app expects. To inspect/edit them:
#   doppler secrets                       # list (dev config)
#   doppler secrets set KEY=value         # set one
#
# ---- Variables -------------------------------------------------------------

# Postgres connection string.
#  - Local dev:  postgresql://USER@localhost:5432/bolao
#  - Production: the POOLED Neon connection string (the one containing "-pooler").
DATABASE_URL=

# Secret used to sign the 30-day session cookie. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Resend API key for sending login codes (https://resend.com).
RESEND_API_KEY=
# Sender address. onboarding@resend.dev only delivers to your own Resend account
# email — verify a domain in Resend to email everyone.
EMAIL_FROM=Bolao da Copa <onboarding@resend.dev>

# Comma-separated emails that get admin powers (manage fixtures + results).
ADMIN_EMAILS=lpontes@luminacm.com

# Comma-separated email domains allowed to log in.
ALLOWED_DOMAINS=luminacm.com,oktcapital.com
